Include ~/.ssh/config.local

Host *
    AddKeysToAgent yes
    PermitLocalCommand yes
    ServerAliveInterval 15
    ServerAliveCountMax 20
    ControlMaster auto
    ControlPersist 600
    ControlPath ~/.ssh/socket/%C

# macOS: 1Password SSH agent (skipped on Linux — socket doesn't exist)
Match host * exec "test -S ~/Library/'Group Containers'/2BUA8C4S2C.com.1password/t/agent.sock"
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    IgnoreUnknown UseKeychain
    UseKeychain yes
